# ---------------------------------------------------------------------------
# Smith Avenue Insights — Quick Suite embed demo environment variables.
#
# Copy this file to .env.local for local development with `vercel dev`.
# In production, set the same vars in the Vercel project's Environment Variables
# UI (Production, Preview, Development).
#
# Vars prefixed VITE_ are baked into the browser bundle at build time.
# All other vars are SERVER-ONLY and read by the /api/embed-url serverless
# function. Never prefix a secret with VITE_.
# ---------------------------------------------------------------------------

# ===== Client-side (exposed to browser) =====

# Cognito User Pool issuer URL (https://cognito-idp.<region>.amazonaws.com/<user-pool-id>)
VITE_COGNITO_AUTHORITY=

# Cognito App Client ID for the SPA (public, no client secret)
VITE_COGNITO_CLIENT_ID=

# Cognito Hosted UI domain, no scheme (e.g. smithave-demo.auth.us-east-1.amazoncognito.com)
VITE_COGNITO_DOMAIN=

# Optional: override the embed-url endpoint. Defaults to /api/embed-url (same-origin Vercel function).
# VITE_EMBED_API_URL=

# Optional: pre-fill IDs in the SPA so the demo page knows what to render.
# If unset, the server-side defaults (QUICKSIGHT_DASHBOARD_ID etc.) are used.
VITE_QUICKSIGHT_DASHBOARD_ID=94f59731-6dc9-4e54-b78d-f709c79ac841
VITE_QUICKSIGHT_TOPIC_ID=
VITE_QUICKSIGHT_AGENT_ID=

# ===== Server-side only (never expose to the browser) =====

# AWS region your Quick Suite account is in.
AWS_REGION=us-east-1

# AWS credentials with quicksight:GenerateEmbedUrlForRegisteredUser permission.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 12-digit AWS Account ID hosting Quick Suite.
AWS_ACCOUNT_ID=

# ARN of the dedicated Quick Suite reader user used to mint all embed URLs.
# e.g. arn:aws:quicksight:us-east-1:123456789012:user/default/smithave-demo-viewer
QUICKSIGHT_USER_ARN=

# Comma-free domain that the embed URL is allowed to load in. Set to your Vercel domain.
# e.g. https://smithaveinsights.com  (Vercel previews also work if you include them in Quick Suite's allow list)
QUICKSIGHT_ALLOWED_DOMAIN=

# Default IDs used when the client doesn't override them.
QUICKSIGHT_DASHBOARD_ID=94f59731-6dc9-4e54-b78d-f709c79ac841
QUICKSIGHT_TOPIC_ID=
QUICKSIGHT_AGENT_ID=

# Cognito values used by the function to verify the access token.
# These are the same as VITE_COGNITO_AUTHORITY / VITE_COGNITO_CLIENT_ID but the
# server reads them without the VITE_ prefix.
COGNITO_ISSUER=
COGNITO_CLIENT_ID=
